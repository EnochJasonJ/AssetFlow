    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "POST /api/v1/auth/signup",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const responseJson = pm.response.json();",
                  "if (responseJson && responseJson.token) {",
                  "    pm.environment.set('token', responseJson.token);",
                  "    pm.globals.set('token', responseJson.token);",
                  "    pm.collectionVariables.set('token', responseJson.token);",
                  "    console.log('Auto-saved token to Postman environment, globals, and collection variables!');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@assetflow.com\",\n  \"password\": \"SecurePass123!\",\n  \"full_name\": \"Alice Admin\",\n  \"role\": \"ADMIN\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "signup"]
            }
          }
        },
        {
          "name": "POST /api/v1/auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const responseJson = pm.response.json();",
                  "if (responseJson && responseJson.token) {",
                  "    pm.environment.set('token', responseJson.token);",
                  "    pm.globals.set('token', responseJson.token);",
                  "    pm.collectionVariables.set('token', responseJson.token);",
                  "    console.log('Auto-saved token to Postman environment, globals, and collection variables!');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@assetflow.com\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          }
